# ── WowStore E2E Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your local values.

# WordPress site URL (no trailing slash)
WP_BASE_URL=http://localhost:8888

# Admin credentials
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password

# WooCommerce REST API keys (generate at WooCommerce → Settings → REST API)
WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret

# WooCommerce test customer credentials
WC_CUSTOMER_USER=customer
WC_CUSTOMER_PASSWORD=customer123

# Optional: WP-CLI path if used in helpers
WP_CLI_PATH=wp
