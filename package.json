{
  "name": "wowstore-e2e-tests",
  "version": "1.0.0",
  "description": "E2E Playwright automation suite for WowStore – Store Builder & Product Blocks for WooCommerce",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:plugin": "playwright test tests/plugin/",
    "test:blocks": "playwright test tests/blocks/",
    "test:store-builder": "playwright test tests/store-builder/",
    "test:frontend": "playwright test tests/frontend/",
    "test:addons": "playwright test tests/addons/",
    "test:woocommerce": "playwright test tests/woocommerce/",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:error": "playwright test tests/error-handling/ --grep @error",
    "test:security": "playwright test tests/security/ --grep @security",
    "report": "playwright show-report",
    "scenarios": "tsx scripts/list-scenarios.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.6.0",
    "@wordpress/e2e-test-utils-playwright": "^0.18.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
